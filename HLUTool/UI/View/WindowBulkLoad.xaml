<controls:ProWindow
    x:Class="HLU.UI.View.WindowBulkLoad"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HLU.UI.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding WindowTitle}"
    MinWidth="480"
    d:DataContext="{d:DesignInstance Type=local:ViewModelWindowBulkLoad}"
    Icon="..\..\Images\HLUTool16.png"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    Style="{DynamicResource ProWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <controls:ProWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionary\ValidationTemplates.xaml" />
                <ResourceDictionary Source="Dictionary\ErrorMessageConverterDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </controls:ProWindow.Resources>

    <DockPanel
        Width="Auto"
        Margin="8"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Layer selection  -->
            <GroupBox Grid.Row="0" Header="Input Layer">
                <Grid Margin="4,8,4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Source layer:" />
                    <ComboBox
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,4,4"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableLayerNames}"
                        SelectedItem="{Binding SelectedLayerName, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Select the non-HLU layer that contains the new features to load." />

                    <!--  Selected Only  -->
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Selected Only"
                        IsEnabled="{Binding HaveSelection}" />
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsChecked="{Binding SelectedOnly}"
                            IsEnabled="{Binding HaveSelection}" />
                        <Label
                            Grid.Column="1"
                            Margin="0,0,4,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="{Binding SelectionText}"
                            IsEnabled="{Binding HaveSelection}" />
                    </Grid>
                </Grid>
            </GroupBox>

            <!--  Field mappings  -->
            <GroupBox Grid.Row="2">
                <GroupBox.Header>
                    <AccessText Text="Field Mappings (input layer field → lut__osmm__habitat__xref column)" />
                </GroupBox.Header>
                <GroupBox.Resources>
                    <!--  Disable each field ComboBox until a layer has been chosen.  -->
                    <Style
                        x:Key="FieldComboStyle"
                        BasedOn="{StaticResource {x:Type ComboBox}}"
                        TargetType="ComboBox">
                        <Setter Property="IsEnabled" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLayerName}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                    <Style
                        x:Key="FieldComboEnabledStyle"
                        BasedOn="{StaticResource {x:Type ComboBox}}"
                        TargetType="ComboBox">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLayerName}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GroupBox.Resources>
                <Grid Margin="4,8,4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  toid (optional)  -->
                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="TOID (optional):" />
                    <ComboBox
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        IsEditable="True"
                        IsReadOnly="True"
                        ItemsSource="{Binding AvailableFieldsWithNone}"
                        SelectedItem="{Binding ToidField, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                        ToolTip="Input layer field that contains the OSMM TOID (optional). When present the TOID is copied into the staging layer and registered in the incid_mm_* table. Select '&lt;None&gt;' if no TOID field is available." />

                    <!--  make  -->
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Make:" />
                    <ComboBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        IsEditable="True"
                        IsReadOnly="True"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding MakeField, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                        ToolTip="Input layer field that corresponds to the OSMM 'make' attribute." />

                    <!--  desc_group  -->
                    <Label
                        Grid.Row="4"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Descriptive Group:" />
                    <ComboBox
                        Grid.Row="4"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        IsEditable="True"
                        IsReadOnly="True"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding DescGroupField, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                        ToolTip="Input layer field that corresponds to the OSMM 'desc_group' attribute." />

                    <!--  desc_term  -->
                    <Label
                        Grid.Row="6"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Descriptive Term:" />
                    <ComboBox
                        Grid.Row="6"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        IsEditable="True"
                        IsReadOnly="True"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding DescTermField, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                        ToolTip="Input layer field that corresponds to the OSMM 'desc_term' attribute." />

                    <!--  theme  -->
                    <Label
                        Grid.Row="8"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Theme:" />
                    <ComboBox
                        Grid.Row="8"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        IsEditable="True"
                        IsReadOnly="True"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding ThemeField, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                        ToolTip="Input layer field that corresponds to the OSMM 'theme' attribute." />

                    <!--  feat_code  -->
                    <Label
                        Grid.Row="10"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Feature Code:" />
                    <ComboBox
                        Grid.Row="10"
                        Grid.Column="1"
                        Margin="0,0,4,4"
                        VerticalAlignment="Center"
                        IsEditable="True"
                        IsReadOnly="True"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding FeatCodeField, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                        ToolTip="Input layer field that corresponds to the OSMM 'feat_code' attribute." />
                </Grid>
            </GroupBox>

            <!--  Output and Selection  -->
            <GroupBox Grid.Row="4" Header="Staging Output">
                <Grid Margin="4,8,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Output Type  -->
                    <Label
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Output Type" />
                    <ComboBox
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        DisplayMemberPath="Display"
                        IsEditable="False"
                        ItemsSource="{Binding OutputTypes}"
                        SelectedValue="{Binding SelectedOutputType, Mode=TwoWay}"
                        SelectedValuePath="Value" />
                </Grid>
            </GroupBox>

            <!--  Ok / Cancel buttons  -->
            <Grid Grid.Row="6" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="82" />
                    <ColumnDefinition Width="82" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    Margin="0,0,2,0"
                    Command="{Binding OkCommand}"
                    Content="_OK"
                    IsDefault="True"
                    Style="{DynamicResource Esri_Button}" />
                <Button
                    Grid.Column="2"
                    Margin="2,0,0,0"
                    Command="{Binding CancelCommand}"
                    Content="_Cancel"
                    IsCancel="True"
                    Style="{DynamicResource Esri_Button}" />
            </Grid>
        </Grid>
    </DockPanel>
</controls:ProWindow>