<UserControl
    x:Class="HLU.UI.View.UserBulkLoadOptions"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:ArcGIS.Desktop.Extensions;assembly=ArcGIS.Desktop.Extensions"
    xmlns:local="clr-namespace:HLU.UI.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=local:ViewModelWindowOptions}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <extensions:DesignOnlyResourceDictionary Source="pack://application:,,,/ArcGIS.Desktop.Framework;component\Themes\Default.xaml" />
                <ResourceDictionary Source="../Dictionary/ErrorMessageConverterDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4">

            <Label
                HorizontalAlignment="Left"
                Content="Set user options for bulk load"
                FontSize="14"
                FontWeight="Medium" />

            <Expander
                Margin="6,10,0,0"
                Header="Bulk Load Options"
                IsExpanded="True">

                <Grid Margin="12,4,4,2" HorizontalAlignment="Left">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="GridDefaultBulkLoadPath" Grid.Row="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Label
                                x:Name="LabelDefaultBulkLoadPath"
                                Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="Default Staging Layer Directory:" />
                            <controls:InfoButton
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="0,0,0,0"
                                Description="The default folder path that will be used for the staging layer when bulk loading data. A different path to the default can still be selected during the bulk load process."
                                Header="Default Staging Layer Directory" />
                        </Grid>

                        <Grid Grid.Row="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="Auto" MinWidth="350" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                x:Name="TextBoxDefaultBulkLoadPath"
                                Grid.Column="1"
                                Height="24"
                                BorderThickness="1"
                                IsEnabled="False"
                                Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                                Text="{Binding DefaultBulkLoadPath, ValidatesOnDataErrors=True}"
                                TextAlignment="Left"
                                ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent}"
                                ToolTipService.ShowOnDisabled="True" />
                            <Button
                                x:Name="ButtonBrowseDefaultBulkLoadPath"
                                Grid.Column="2"
                                Width="24"
                                Height="24"
                                MinWidth="0"
                                MinHeight="0"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding BrowseDefaultBulkLoadPathCommand}"
                                Style="{DynamicResource Esri_SmallButton}"
                                ToolTip="Select default staging layer path"
                                ToolTipService.ShowOnDisabled="True">
                                <Image
                                    Width="16"
                                    Height="16"
                                    Source="{Binding ButtonOpenFolderImg}" />
                            </Button>
                        </Grid>
                    </Grid>

                    <Grid
                        x:Name="GridBulkLoadLayer"
                        Grid.Row="2"
                        HorizontalAlignment="Left">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="170" />
                            <ColumnDefinition Width="Auto" MinWidth="300" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label
                            x:Name="LabelBulkLoadLayer"
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="Default Staging Layer Name" />
                        <TextBox
                            x:Name="TextBoxBulkLoadLayer"
                            Grid.Column="1"
                            BorderThickness="1"
                            Tag="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent, Converter={StaticResource errorMessageConverter}}"
                            Text="{Binding DefaultBulkLoadLayer, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent}"
                            ToolTipService.ShowOnDisabled="True" />
                        <controls:InfoButton
                            Grid.Column="2"
                            Margin="5,0,0,0"
                            Description="The default name of the staging layer that will be created during the bulk load process."
                            Header="Default Staging Layer Name" />
                    </Grid>
                </Grid>
            </Expander>
        </StackPanel>

        <TextBlock
            Grid.Row="1"
            Margin="8,0,0,10"
            HorizontalAlignment="Left"
            FontWeight="Medium">
            <Hyperlink
                Command="{Binding OpenHyperlinkCommand}"
                CommandParameter="{Binding NavigateUri, RelativeSource={RelativeSource Self}}"
                NavigateUri="{Binding Hyperlink_UserBulkLoadHelp}">
                Learn more about user bulk load options
            </Hyperlink>
        </TextBlock>
    </Grid>
</UserControl>