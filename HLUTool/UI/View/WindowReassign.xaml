<controls:ProWindow
    x:Class="HLU.UI.View.WindowReassign"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HLU.UI.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding WindowTitle}"
    Width="770"
    MinWidth="770"
    MinHeight="380"
    d:DataContext="{d:DesignInstance Type=local:ViewModelWindowReassign}"
    Icon="..\..\Images\HLUTool16.png"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    SizeToContent="Manual"
    Style="{DynamicResource ProWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <controls:ProWindow.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionary\ValidationTemplates.xaml" />
                <ResourceDictionary Source="Dictionary\ErrorMessageConverterDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </controls:ProWindow.Resources>

    <DockPanel
        Width="Auto"
        Margin="4,4,4,4"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="*" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Source Layer  -->
            <GroupBox
                Name="GroupBoxSource"
                Grid.Row="0"
                Header="Source Layer">
                <Grid Margin="8,8,8,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        Name="TextBoxSourceLayer"
                        Grid.Row="0"
                        IsEnabled="False"
                        Text="{Binding SourceLayerName, Mode=OneWay}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="Total features:" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{Binding TotalSourceFeaturesText}" />

                        <TextBlock
                            Grid.Column="4"
                            VerticalAlignment="Center"
                            Text="Total in rules:" />
                        <TextBlock
                            Grid.Column="6"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{Binding TotalRuleFeaturesText}" />
                        <TextBlock
                            Grid.Column="8"
                            FontWeight="SemiBold"
                            Foreground="DarkOrange"
                            Text="{Binding FeatureCountMismatchMessage}"
                            Visibility="{Binding ShowFeatureCountMismatch, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>

                </Grid>
            </GroupBox>

            <!--  Rules Grid  -->
            <GroupBox
                Name="GroupBoxRules"
                Grid.Row="2"
                Header="Reassign Rules">
                <DataGrid
                    Name="DataGridRules"
                    Margin="2,8,2,2"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeRows="False"
                    CanUserSortColumns="False"
                    ItemsSource="{Binding RuleRows}"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <!--  Rule Name  -->
                        <DataGridTextColumn
                            MinWidth="100"
                            Binding="{Binding RuleName}"
                            Header="Rule"
                            IsReadOnly="True" />

                        <!--  Where Clause  -->
                        <DataGridTextColumn
                            Width="*"
                            MinWidth="400"
                            MaxWidth="800"
                            Binding="{Binding WhereClause}"
                            Header="Where Clause"
                            IsReadOnly="True" />

                        <!--  Feature Count  -->
                        <DataGridTextColumn
                            MinWidth="80"
                            Binding="{Binding FeatureCountText}"
                            Header="Features"
                            IsReadOnly="True" />

                        <!--  Target Layer  -->
                        <DataGridComboBoxColumn
                            MinWidth="150"
                            Header="Target Layer"
                            SelectedItemBinding="{Binding SelectedTargetLayer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.TargetLayerNamesWithSkip, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                    <Setter Property="IsEnabled" Value="{Binding CanReassign}" />
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.TargetLayerNamesWithSkip, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                    <Setter Property="IsEnabled" Value="{Binding CanReassign}" />
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!--  Ok / Cancel buttons  -->
            <Grid Grid.Row="4" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="82" />
                    <ColumnDefinition Width="82" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    Margin="0,0,2,0"
                    Command="{Binding OkCommand}"
                    Content="_OK"
                    IsDefault="True"
                    Style="{DynamicResource Esri_Button}" />
                <Button
                    Grid.Column="2"
                    Margin="2,0,0,0"
                    Command="{Binding CancelCommand}"
                    Content="_Cancel"
                    IsCancel="True"
                    Style="{DynamicResource Esri_Button}" />
            </Grid>
        </Grid>
    </DockPanel>
</controls:ProWindow>