<controls:ProWindow
    x:Class="HLU.UI.View.WindowOSMMBulkLoad"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:HLU.UI.ViewModel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding WindowTitle}"
    MinWidth="480"
    d:DataContext="{d:DesignInstance Type=local:ViewModelWindowOSMMBulkLoad}"
    Icon="..\..\Images\HLUTool16.png"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    Style="{DynamicResource ProWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <controls:ProWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dictionary\ValidationTemplates.xaml" />
                <ResourceDictionary Source="Dictionary\ErrorMessageConverterDictionary.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </controls:ProWindow.Resources>

    <DockPanel
        Width="Auto"
        Margin="4"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Layer selection  -->
            <GroupBox Grid.Row="0" Header="Input Layer">
                <Grid Margin="4,8,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Label
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="OSMM source layer:" />
                    <ComboBox
                        Grid.Column="1"
                        Margin="0,0,4,4"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableLayerNames}"
                        SelectedItem="{Binding SelectedLayerName, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="Select the non-HLU layer that contains the new OSMM features to load." />
                </Grid>
            </GroupBox>

            <!--  Field mappings  -->
            <GroupBox Grid.Row="2" Header="Field Mappings  (input layer field → lut_osmm_habitat_xref column)">
                <GroupBox.Resources>
                    <!--  Disable each field ComboBox until a layer has been chosen.  -->
                    <Style
                        x:Key="FieldComboStyle"
                        BasedOn="{StaticResource {x:Type ComboBox}}"
                        TargetType="ComboBox">
                        <Setter Property="IsEnabled" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLayerName}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                    <Style
                        x:Key="FieldComboEnabledStyle"
                        BasedOn="{StaticResource {x:Type ComboBox}}"
                        TargetType="ComboBox">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedLayerName}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GroupBox.Resources>
                <Grid Margin="4,8,4,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  toid (optional)  -->
                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="toid (optional):" />
                    <ComboBox
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding ToidField, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        ToolTip="Input layer field that contains the OSMM TOID (optional). When present the TOID is copied into the staging layer and registered in the incid_mm_* table." />

                    <!--  make  -->
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="make:" />
                    <ComboBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding MakeField, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        ToolTip="Input layer field that corresponds to the OSMM 'make' attribute." />

                    <!--  desc_group  -->
                    <Label
                        Grid.Row="4"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="desc_group:" />
                    <ComboBox
                        Grid.Row="4"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding DescGroupField, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        ToolTip="Input layer field that corresponds to the OSMM 'desc_group' attribute." />

                    <!--  desc_term  -->
                    <Label
                        Grid.Row="6"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="desc_term:" />
                    <ComboBox
                        Grid.Row="6"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding DescTermField, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        ToolTip="Input layer field that corresponds to the OSMM 'desc_term' attribute." />

                    <!--  theme  -->
                    <Label
                        Grid.Row="8"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="theme:" />
                    <ComboBox
                        Grid.Row="8"
                        Grid.Column="1"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding ThemeField, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        ToolTip="Input layer field that corresponds to the OSMM 'theme' attribute." />

                    <!--  feat_code  -->
                    <Label
                        Grid.Row="10"
                        Grid.Column="0"
                        Margin="4,0,8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="feat_code:" />
                    <ComboBox
                        Grid.Row="10"
                        Grid.Column="1"
                        Margin="0,0,4,4"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding AvailableFields}"
                        SelectedItem="{Binding FeatCodeField, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource FieldComboEnabledStyle}"
                        ToolTip="Input layer field that corresponds to the OSMM 'feat_code' attribute." />
                </Grid>
            </GroupBox>

            <!--  Output layer  -->
            <GroupBox Grid.Row="4" Header="Output Layer">
                <StackPanel Margin="4,8,4,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label
                            Grid.Column="0"
                            Margin="4,0,8,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="Output staging layer:" />
                        <TextBox
                            Grid.Column="1"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            IsReadOnly="True"
                            Text="{Binding OutputDisplayPath, Mode=OneWay}"
                            ToolTip="The shapefile or geodatabase feature class to write the staged OSMM features to." />
                        <Button
                            Grid.Column="2"
                            Width="70"
                            Margin="0,0,4,0"
                            Command="{Binding BrowseOutputCommand}"
                            Content="Browse..."
                            Style="{DynamicResource Esri_SimpleButton}" />
                    </Grid>

                    <!--  Error: output path is required  -->
                    <TextBlock
                        Margin="144,4,4,0"
                        FontWeight="Medium"
                        Foreground="Red"
                        Text="An output layer path is required."
                        TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OutputDisplayPath}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!--  Warning: output already exists  -->
                    <TextBlock
                        Margin="144,4,4,0"
                        FontWeight="Medium"
                        Foreground="DarkOrange"
                        Text="{Binding OutputExistsWarning}"
                        TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OutputExistsWarning}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <!--  Ok / Cancel buttons  -->
            <Grid Grid.Row="6" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    Width="75"
                    Command="{Binding OkCommand}"
                    Content="OK"
                    IsDefault="True"
                    Style="{DynamicResource Esri_SimpleButton}" />
                <Button
                    Grid.Column="3"
                    Width="75"
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    IsCancel="True"
                    Style="{DynamicResource Esri_SimpleButton}" />
            </Grid>
        </Grid>
    </DockPanel>
</controls:ProWindow>